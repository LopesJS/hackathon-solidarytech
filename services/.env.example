# Copie este arquivo para .env e ajuste se necessário.
# Valores abaixo funcionam prontos para desenvolvimento local (Postgres + LocalStack).
# NUNCA coloque credenciais reais de AWS aqui — em produção elas vêm do Secrets Manager.

# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=solidary
POSTGRES_PASSWORD=solidary_local_pw
POSTGRES_DB=postgres
NGO_DATABASE_URL=postgres://solidary:solidary_local_pw@postgres:5432/ngo_db
DONATION_DATABASE_URL=postgres://solidary:solidary_local_pw@postgres:5432/donation_db

# ─── AWS (LocalStack — valores fake, não usar em produção) ────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566
AWS_DYNAMODB_TABLE=SolidaryTechVolunteers
AWS_SQS_URL=http://localstack:4566/000000000000/solidary-donations
